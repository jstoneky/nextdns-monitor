{
  "manifest_version": 2,
  "name": "NextDNS Medic",
  "short_name": "NextDNS Monitor",
  "version": "2.3.1",
  "description": "Detects NextDNS blocks that break websites. Groups domains by risk level and lets you allowlist them instantly via the NextDNS API.",
  "permissions": [
    "webRequest",
    "tabs",
    "storage",
    "activeTab",
    "webNavigation",
    "<all_urls>",
    "https://raw.githubusercontent.com/jstoneky/nextdns-medic/*",
    "clipboardWrite"
  ],
  "background": {
    "scripts": [
      "browser-compat.js",
      "domain-db.js",
      "db-loader.js",
      "background.js"
    ],
    "persistent": false
  },
  "browser_action": {
    "default_popup": "popup.html",
    "default_title": "NextDNS Medic",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "homepage_url": "https://github.com/jstoneky/nextdns-monitor",
  "browser_specific_settings": {
    "gecko": {
      "id": "nextdns-medic@jstoneky.github.io",
      "strict_min_version": "109.0",
      "data_collection_permissions": {
        "required": [
          "none"
        ],
        "optional": []
      }
    }
  }
}